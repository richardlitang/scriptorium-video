          "media": [
            {
              "id": "the-warning-001-visual",
              "type": "title_card",
              "role": "primary_visual",
              "prompt": "Over-the-shoulder shot showing a dark figure behind the protagonist.",
              "scaleMode": "cover",
              "placement": "background"
            }
          ],
          "motion": {
            "type": "none",
            "intensity": 0.08
          },
          "caption": {
            "emphasis": [
              "whisper",
              "tension"
