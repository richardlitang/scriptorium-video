              "id": "the-discovery-001-visual",
              "type": "title_card",
              "role": "primary_visual",
              "prompt": "Wide shot of an empty parking lot at night, dimly lit with a single streetlight.",
              "scaleMode": "cover",
              "placement": "background"
            }
          ],
          "motion": {
            "type": "none",
            "intensity": 0.08
          },
          "caption": {
            "emphasis": [],
