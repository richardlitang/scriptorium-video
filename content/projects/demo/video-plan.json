      "estimatedDurationSeconds": 13,
      "beats": [
        {
          "id": "the-warning-001",
          "order": 1,
          "narration": "Before I could speak, a woman whispered, “Don’t turn around.”",
          "timing": {
            "estimatedDurationSeconds": 5,
            "preferredMinSeconds": 4,
            "preferredMaxSeconds": 20,
            "mediaPolicy": "loop_or_freeze"
