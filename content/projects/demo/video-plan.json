            "style": "default"
          },
          "notes": "Convey fear and dread."
        },
        {
          "id": "the-warning-003",
          "order": 3,
          "narration": "Then I heard it. Footsteps behind me. Slow. One step. Then another.",
          "timing": {
            "estimatedDurationSeconds": 5,
            "preferredMinSeconds": 4,
            "preferredMaxSeconds": 20,
            "mediaPolicy": "loop_or_freeze"
