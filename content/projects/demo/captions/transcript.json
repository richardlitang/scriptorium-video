    },
    {
      "startSeconds": 27.168,
      "endSeconds": 30.48,
      "text": "My stomach dropped. I froze."
    },
    {
      "startSeconds": 30.48,
      "endSeconds": 36.336,
      "text": "Then I heard it. Footsteps behind me. Slow. One step. Then another."
    },
    {
      "startSeconds": 36.336,
      "endSeconds": 43.44,
      "text": "The woman on the phone started crying. 'Please,' she said. 'He already has my son.'"
    },
    {
      "startSeconds": 43.44,
      "endSeconds": 45.888,
      "text": "I turned anyway."
    },
    {
      "startSeconds": 45.888,
      "endSeconds": 52.8,
      "text": "And standing under the only broken streetlight… was a little boy. Holding my exact same phone."
    },
