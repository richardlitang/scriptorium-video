{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": [
    "server.mjs",
    "static-assets.mjs",
    "image-cache.mjs",
    "voice-settings.mjs",
    "lib/**/*.mjs",
    "lib/**/*.mts",
    "*.mts",
    "test/**/*.mts"
  ],
  "exclude": ["web", "node_modules"]
}
