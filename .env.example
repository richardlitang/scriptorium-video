# Local Video Studio environment
#
# Copy values into your shell or local env file. Do not commit real secrets.

# Studio server
PORT=4173
LVSTUDIO_TEST_MODE=0
LVSTUDIO_RUN_SERVER_TESTS=0

# OpenAI planning, image generation, and TTS
OPENAI_API_KEY=
LVSTUDIO_OPENAI_ENV_FILE=
OPENAI_PLANNER_MODEL=gpt-5.4-mini
OPENAI_PLANNER_FALLBACK_MODELS=gpt-5-mini,gpt-4.1-mini
OPENAI_PLANNER_REQUEST_TIMEOUT_MS=
OPENAI_PLANNER_REQUEST_MAX_ATTEMPTS=
OPENAI_ORCHESTRATOR_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2
LVSTUDIO_IMAGE_CONCURRENCY=2
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_REQUEST_TIMEOUT_MS=90000
OPENAI_REQUEST_MAX_ATTEMPTS=3
OPENAI_STRUCTURED_OUTPUT_FALLBACK_MODELS=

# Studio planner behavior
LVSTUDIO_SPLIT_PLANNER_BEATS_PER_SECTION=24
LVSTUDIO_SPLIT_PLANNER_MAX_SECTIONS=6
LVSTUDIO_SPLIT_PLANNER_SECTION_ATTEMPTS=2
LVSTUDIO_SPLIT_PLANNER=1
LVSTUDIO_SPLIT_PLANNER_MIN_WORDS=2500
LVSTUDIO_SPLIT_PLANNER_MIN_UNITS=40
LVSTUDIO_OPENAI_TTS_ROUTING=0
OPENAI_TTS_ROUTING_MODEL=gpt-4o-mini

# TTS routing and concurrency
LVSTUDIO_TTS_MODE=local
LVSTUDIO_TTS_FALLBACK_PROVIDER=
LVSTUDIO_TTS_PROVIDER_BY_LANGUAGE=
LVSTUDIO_TTS_CONCURRENCY=

# Chatterbox TTS
CHATTERBOX_TTS_URL=http://127.0.0.1:8000/v1/audio/speech
CHATTERBOX_TTS_API_KEY=
CHATTERBOX_TTS_MODEL=chatterbox
CHATTERBOX_TTS_VOICE_ID=default
CHATTERBOX_AUDIO_PROMPT_PATH=
CHATTERBOX_EXAGGERATION=
CHATTERBOX_CFG_WEIGHT=
CHATTERBOX_TEMPERATURE=
CHATTERBOX_SEED=
CHATTERBOX_MODEL_CACHE=/private/tmp/lvstudio-hf
LVSTUDIO_CHATTERBOX_AUTOSTART=1
LVSTUDIO_CHATTERBOX_PYTHON=/private/tmp/lvstudio-chatterbox-venv/bin/python
LVSTUDIO_CHATTERBOX_START_SCRIPT=
LVSTUDIO_CHATTERBOX_START_TIMEOUT_MS=45000

# MMS TTS
MMS_TTS_URL=http://127.0.0.1:8001/v1/audio/speech
MMS_TTS_MODEL=facebook/mms-tts-tgl
MMS_TTS_LANGUAGE=tgl

# Renderer
LVSTUDIO_REMOTION_PORT=
LVSTUDIO_REMOTION_TIMEOUT_MS=120000

# Audio, sound effects, and music
LVSTUDIO_SFX_LIBRARY_DIR=
LVSTUDIO_DEFAULT_MUSIC_BED=
LVSTUDIO_ENABLE_AUTO_MUSIC_BED=1
LVSTUDIO_MUSIC_BED_LEVEL_DB=-24
